# =========================================================
# DataSpot AI — root environment reference
# Copy the relevant values into frontend/.env.local and
# backend/.env — this file documents every variable used
# across the monorepo in one place.
# =========================================================

# ---- Frontend (frontend/.env.local) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_USE_MOCKS=true

# ---- Backend (backend/.env) ----
ENVIRONMENT=local
LOG_LEVEL=INFO

# AWS core
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# S3 (dataset storage)
S3_BUCKET_NAME=dataspot-ai-datasets
S3_SIGNED_URL_EXPIRY_SECONDS=900

# Bedrock AgentCore
BEDROCK_AGENTCORE_REGION=us-east-1
BEDROCK_AGENTCORE_RUNTIME_ENDPOINT=
BEDROCK_AGENTCORE_ROLE_ARN=
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# RAG / vector store
VECTOR_STORE_PROVIDER=local_faiss   # local_faiss | opensearch | bedrock_kb
OPENSEARCH_COLLECTION_ENDPOINT=
BEDROCK_KNOWLEDGE_BASE_ID=
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
