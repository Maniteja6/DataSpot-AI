ENVIRONMENT=local
LOG_LEVEL=INFO
API_PORT=8000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app

# Local storage (used when AWS isn't configured — see utils/mock_interfaces.py)
LOCAL_STORAGE_DIR=./storage/uploads
VECTOR_INDEX_DIR=./storage/vector_index

# AWS core
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# S3 (dataset storage) — leave S3_BUCKET_NAME empty to use local disk storage
S3_BUCKET_NAME=
S3_SIGNED_URL_EXPIRY_SECONDS=900

# Bedrock AgentCore — leave BEDROCK_AGENTCORE_RUNTIME_ENDPOINT empty to use
# the local deterministic agent fallback (no AWS calls, fully offline demo)
BEDROCK_AGENTCORE_REGION=us-east-1
BEDROCK_AGENTCORE_RUNTIME_ENDPOINT=
BEDROCK_AGENTCORE_ROLE_ARN=
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Lightweight alternative to a deployed AgentCore Runtime — calls Claude
# directly via bedrock-runtime Converse API. Requires Bedrock model access
# enabled for BEDROCK_MODEL_ID in AWS_REGION.
BEDROCK_DIRECT_INVOKE=false

# RAG / vector store
VECTOR_STORE_PROVIDER=local_faiss   # local_faiss | opensearch | bedrock_kb
OPENSEARCH_COLLECTION_ENDPOINT=
# bedrock_kb needs a real Knowledge Base + Aurora PostgreSQL (pgvector)
# backend already stood up — see infra/aws/aurora_pgvector_config.yaml and
# the "Bedrock Knowledge Base (Aurora pgvector)" section of
# infra/deployment_notes.md before setting this. No new AWS credentials are
# needed here beyond AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY above — this
# backend only writes documents to S3 and triggers a sync job; Bedrock talks
# to Aurora on AWS's side, not through this backend's own DB connection.
BEDROCK_KNOWLEDGE_BASE_ID=
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
